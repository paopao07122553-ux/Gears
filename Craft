--- 🛠️ ระบบตรวจจับเวอร์ชันแก้บัค (Anti-Bug Logic) 🛠️ ---
local autoCraftActive = false
local remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
local craftTrophy = remotes:WaitForChild("CraftTrophy")

-- ฟังก์ชันพิเศษ: เช็คว่า UI ตัวนี้เปิดแสดงผลอยู่บนหน้าจอจริงๆ ไหม (แก้ปัญหาเจอ UI ซ่อน)
local function isUiRealAndVisible(obj)
    local current = obj
    while current and current:IsA("GuiObject") do
        if not current.Visible then
            return false -- ถ้ามีโฟลเดอร์ต้นสังกัดตัวไหนปิดอยู่ แปลว่าเป็น UI ที่เกมซ่อนไว้
        end
        current = current.Parent
    end
    return true
end

local function checkItemStock(itemName)
    if itemName == "" or itemName == "พิมพ์ชื่อไอเทมชิ้นที่ 1..." or itemName == "พิมพ์ชื่อไอเทมชิ้นที่ 2 (ถ้ามี)..." then 
        return "EMPTY" 
    end
    
    local lowerName = itemName:lower()
    local playerGui = game:GetService("Players").LocalPlayer:findFirstChild("PlayerGui")
    
    if playerGui then
        -- สแกนหาข้อความชื่อไอเทม
        for _, v in pairs(playerGui:GetDescendants()) do
            if (v:IsA("TextLabel") or v:IsA("TextButton")) and v.Text:lower():find(lowerName) then
                
                -- ตรวจสอบว่าปุ่มนี้มองเห็นอยู่บนจอจริงๆ ไม่ใช่พวก Template ที่ซ่อนอยู่
                if isUiRealAndVisible(v) then
                    local itemFrame = v.Parent
                    local outOfStock = false
                    
                    -- ใช้ GetDescendants สแกนลึกทะลุทุกโฟลเดอร์ย่อยในกรอบไอเทมชิ้นนั้น
                    for _, child in pairs(itemFrame:GetDescendants()) do
                        if child:IsA("TextLabel") or child:IsA("TextButton") then
                            local txt = child.Text:lower()
                            
                            -- เพิ่มคีย์เวิร์ดดักทุกทาง (Out of Stock, Sold Out, หมด, เลข 0 ตัวเดียว หรือพวก 0/10)
                            if txt:find("out") or txt:find("sold") or txt:find("หมด") or txt:find("stock: 0") or txt:find("0 left") or txt:find("0/") or txt == "0" then
                                outOfStock = true
                                break
                            end
                        end
                    end
                    
                    if outOfStock then
                        return "OUT_OF_STOCK"
                    else
                        return "IN_STOCK"
                    end
                end
            end
        end
    end
    return "NOT_FOUND"
end

-- ระบบปุ่มทำงาน
ToggleButton.MouseButton1Click:Connect(function()
    autoCraftActive = not autoCraftActive
    
    if autoCraftActive then
        ToggleButton.Text = "ระบบตรวจจับกำลังทำงาน (ON)"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        task.spawn(function()
            while autoCraftActive do
                local item1 = TextBox1.Text
                local item2 = TextBox2.Text
                
                local status1 = checkItemStock(item1)
                local status2 = checkItemStock(item2)
                
                local displayTxt = ""
                
                -- เช็คชิ้นที่ 1
                if status1 == "IN_STOCK" then
                    displayTxt = displayTxt .. "[1] In Stock! กำลังคราฟต์..\n"
                    craftTrophy:FireServer(item1)
                elseif status1 == "OUT_OF_STOCK" then
                    displayTxt = displayTxt .. "[1] รอเติม (Out of Stock)\n"
                elseif status1 == "NOT_FOUND" then
                    displayTxt = displayTxt .. "[1] ไม่พบร้านค้า (เปิดจอรอนะ)\n"
                end
                
                -- เช็คชิ้นที่ 2
                if status2 == "IN_STOCK" then
                    displayTxt = displayTxt .. "[2] In Stock! กำลังคราฟต์.."
                    craftTrophy:FireServer(item2)
                elseif status2 == "OUT_OF_STOCK" then
                    displayTxt = displayTxt .. "[2] รอเติม (Out of Stock)"
                elseif status2 == "NOT_FOUND" then
                    displayTxt = displayTxt .. "[2] ไม่พบร้านค้า (เปิดจอรอนะ)"
                end
                
                StatusLabel.Text = displayTxt
                
                if status1 == "IN_STOCK" or status2 == "IN_STOCK" then
                    StatusLabel.TextColor3 = Color3.fromRGB(50, 255, 50)
                    task.wait(2) -- คราฟต์สำเร็จหน่วงเวลาแป๊บนึง
                else
                    StatusLabel.TextColor3 = Color3.fromRGB(255, 230, 100) -- สีเหลืองนวลระหว่างสแกนรอ
                end
                
                task.wait(1)
            end
        end)
    else
        ToggleButton.Text = "เริ่มตรวจจับระบบใหม่ (OFF)"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        StatusLabel.Text = "สถานะ: ปิดการทำงาน"
        StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)
